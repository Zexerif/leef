{
  "name": "private-browser",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "preview": "vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.quinn.leefbrowser",
    "productName": "Leef Browser",
    "files": [
      "!**/.vscode/*",
      "!src/*",
      "main.js",
      "renderer.js",
      "index.html",
      "style.css"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "asar": true
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^8.0.4"
  }
}
